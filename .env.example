# Spotify Developer API Credentials (from https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3001/api/auth/callback

# Frontend URL (For Dev, Vite runs on 5173 by default)
CLIENT_URL=http://localhost:5173

# Server URL & Port
PORT=3001
SERVER_URL=http://localhost:3001

# JWT Secret for encrypting/verifying local session tokens
JWT_SECRET=super_secret_musicmap_key_change_me
